# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — raises Semantic Scholar rate limits
SEMANTIC_SCHOLAR_API_KEY=

# Optional — for GPU experiments via Modal
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Optional — for gated HuggingFace datasets
HF_TOKEN=

# Optional — NVIDIA API
NVIDIA_API_KEY=

# Defaults (uncomment to override)
# LOG_LEVEL=INFO
# MAX_PAPERS_PER_CYCLE=50
# EXPERIMENT_TIMEOUT_SECONDS=3600
# ENABLE_EXPERIMENT_NETWORK=true
